rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // El paciente (sin auth) puede leer sedes, horarios y excepciones
    match /sedes/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /horarios/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /excepciones/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // El paciente puede crear citas y pacientes, pero no modificarlos
    match /citas/{document} {
      allow read: if request.auth != null;
      allow create: if request.resource.data is map;
      allow update, delete: if request.auth != null;
    }

    match /pacientes/{document} {
      allow read: if request.auth != null;
      allow create: if request.resource.data is map;
      allow update, delete: if request.auth != null;
    }

    // Profesionales: solo lectura pública, escritura solo auth
    match /profesionales/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notificaciones: solo usuarios autenticados
    match /notificaciones/{document} {
      allow read, write: if request.auth != null;
    }

    // Tipos de consulta: lectura pública, escritura solo auth
    match /tipos_consulta/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Versión de la app: lectura pública, escritura solo auth
    match /app_version/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
